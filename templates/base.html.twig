<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Urban's Food — Street food à Lyon{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Tacos, smash burgers et sauces maison à Tassin-la-Demi-Lune, près de Lyon. Street food prise au sérieux depuis 2021.{% endblock %}">
        {% block robots %}{% endblock %}
        <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
        <meta property="og:type" content="website">
        <meta property="og:site_name" content="Urban's Food">
        <meta property="og:locale" content="fr_FR">
        <meta property="og:title" content="{{ block('title') }}">
        <meta property="og:description" content="{{ block('meta_description') }}">
        <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
        <meta name="twitter:card" content="summary">
        <meta name="theme-color" content="#F2EFE7">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 fill=%22%231E7A34%22/><text y=%2288%22 x=%2264%22 text-anchor=%22middle%22 font-size=%2264%22 font-family=%22sans-serif%22 font-weight=%22bold%22 fill=%22%23F2EFE7%22>UF</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        {% if plausible_domain %}
            <script>window.ufAnalytics = { provider: 'plausible', domain: {{ plausible_domain|json_encode|raw }} };</script>
        {% endif %}

    </head>
    <body>
        {% block header %}{{ include('partials/_header.html.twig') }}{% endblock %}
        {% block body %}{% endblock %}
        {% block footer %}{{ include('partials/_footer.html.twig') }}{% endblock %}
        <button type="button" class="uf-totop" aria-label="Revenir en haut de la page">↑</button>
        {{ include('partials/_cookie_banner.html.twig') }}
    </body>
</html>
