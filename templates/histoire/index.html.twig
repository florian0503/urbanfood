{% extends 'base.html.twig' %}

{% block title %}Notre Histoire — Urban's Food{% endblock %}

{% block body %}
    <header class="uf-page-head">
        <div class="uf-container uf-page-head__inner">
            <div data-reveal="0" class="uf-page-head__label">L'HISTOIRE — 2021 → AUJOURD'HUI</div>
            <h1 data-reveal="80" class="uf-page-head__title">D'un camion<br>à <span class="uf-page-head__accent">la Guillotière.</span></h1>
        </div>
    </header>

    <section class="uf-container uf-story">
        <div>
            <p data-reveal="0" class="uf-story__lead">
                Urban's Food a commencé avec un camion garé place Gabriel-Péri, trois recettes de tacos et une conviction : la street food mérite le même sérieux qu'un bistrot.
            </p>
            <p data-reveal="100" class="uf-story__text">
                Deux ans plus tard, le camion est devenu un local de 60 places. Les murs ont été confiés à des graffeurs du quartier, la cuisine est restée ouverte sur la salle — on voit tout, on sent tout, rien à cacher.
            </p>
            <p data-reveal="200" class="uf-story__text uf-story__text--last">
                Aujourd'hui l'équipe compte neuf personnes, la carte a doublé, et le Carnivore part à plus de cent exemplaires chaque samedi. La suite ? Un deuxième spot, quelque part sur la rive gauche.
            </p>
        </div>
        <div data-reveal="150" class="uf-story__visuals">
            <div class="uf-story__photo uf-story__photo--tall"><span>[ photo — le camion, 2021 ]</span></div>
            <div class="uf-story__photo"><span>[ photo — l'équipe devant le local ]</span></div>
        </div>
    </section>

    <section class="uf-timeline">
        <div class="uf-container uf-timeline__inner">
            <div data-reveal="0" class="uf-timeline__label">— LES DATES</div>
            <div class="uf-timeline__grid">
                <div data-reveal="0" class="uf-timeline__step">
                    <div class="uf-timeline__year">2021</div>
                    <div class="uf-timeline__title">Le camion</div>
                    <p class="uf-timeline__text">Trois recettes de tacos, un compte Instagram, et des files d'attente qui s'allongent place Gabriel-Péri.</p>
                </div>
                <div data-reveal="100" class="uf-timeline__step">
                    <div class="uf-timeline__year">2023</div>
                    <div class="uf-timeline__title">Le local</div>
                    <p class="uf-timeline__text">Ouverture à la Guillotière : 60 places, murs graffés par des artistes du quartier, cuisine ouverte.</p>
                </div>
                <div data-reveal="200" class="uf-timeline__step">
                    <div class="uf-timeline__year">2025</div>
                    <div class="uf-timeline__title">La carte double</div>
                    <p class="uf-timeline__text">Arrivée des smash burgers et de la formule étudiant. Le Carnivore devient intouchable.</p>
                </div>
                <div data-reveal="300" class="uf-timeline__step">
                    <div class="uf-timeline__year">2026</div>
                    <div class="uf-timeline__title">La suite</div>
                    <p class="uf-timeline__text">Un deuxième spot en préparation, quelque part sur la rive gauche du Rhône.</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
