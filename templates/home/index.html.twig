{% extends 'base.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Restaurant",
        "name": "Urban's Food",
        "url": "{{ app.request.schemeAndHttpHost }}",
        "telephone": "+33472000000",
        "servesCuisine": ["Street food", "Tacos", "Smash burgers"],
        "priceRange": "€",
        "address": {
            "@type": "PostalAddress",
            "postalCode": "69160",
            "addressLocality": "Tassin-la-Demi-Lune",
            "addressCountry": "FR"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 45.7630,
            "longitude": 4.7800
        },
        "openingHoursSpecification": [
            {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
                "opens": "11:00",
                "closes": "22:30"
            },
            {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Friday", "Saturday"],
                "opens": "11:00",
                "closes": "23:30"
            },
            {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": "Sunday",
                "opens": "12:00",
                "closes": "22:00"
            }
        ],
        "hasMenu": "{{ url('app_carte') }}"
    }
    </script>
{% endblock %}

{% block body %}
    <header class="uf-hero">
        <div class="uf-hero__placeholder">
            <span>[ vidéo — plan cuisine / smash pressé, en boucle ]</span>
        </div>
        <video autoplay muted loop playsinline aria-hidden="true" data-uf-video="1" src="https://videos.pexels.com/video-files/8477267/8477267-hd_1920_1080_24fps.mp4" class="uf-hero__video"></video>
        <div class="uf-hero__overlay"></div>
        <div class="uf-container uf-hero__content">
            <div data-reveal="0" class="uf-hero__meta">
                <span>N°01 — TASSIN-LA-DEMI-LUNE</span>
                <span class="uf-hero__meta-right">OUVERT 7J/7 · 11H–23H <span class="uf-open-badge" hidden></span></span>
            </div>
            <h1 class="uf-hero__title">
                <span data-reveal="80" class="uf-hero__line">Tacos, smash</span>
                <span data-reveal="180" class="uf-hero__line uf-hero__line--green">&amp; sauces maison<span class="uf-hero__dot">.</span></span>
            </h1>
            <div class="uf-hero__bottom">
                <p data-reveal="280" class="uf-hero__text">
                    De la street food prise au sérieux : viandes préparées le matin même, pain toasté minute, douze sauces faites ici. Rien d'autre.
                </p>
                <a data-reveal="360" href="{{ path('app_carte') }}" class="uf-hero__cta">Voir la carte <span class="uf-hero__cta-arrow">→</span></a>
            </div>
        </div>
        <div class="uf-hero__stamp">FAIT<br>MAISON<br>★★★</div>
    </header>

    <div class="uf-marquee">
        <div class="uf-marquee__track">
            {% for i in 1..2 %}
                <span class="uf-marquee__text">DOUZE SAUCES MAISON — VIANDE FRANÇAISE — PAIN TOASTÉ MINUTE — FRITES COUPÉES SUR PLACE — DOUZE SAUCES MAISON — VIANDE FRANÇAISE — PAIN TOASTÉ MINUTE — FRITES COUPÉES SUR PLACE —&nbsp;</span>
            {% endfor %}
        </div>
    </div>

    <section class="uf-container uf-featured">
        <div data-reveal="0" class="uf-featured__head">
            <h2 class="uf-featured__title">Les incontournables</h2>
            <span class="uf-featured__count">({{ '%02d'|format(featured_items|length) }})</span>
        </div>
        <div class="uf-featured__list">
            {% for item in featured_items %}
                <a href="{{ path('app_carte') }}" data-reveal="{{ loop.index0 * 90 }}" class="uf-featured__item">
                    <span class="uf-featured__num">{{ '%02d'|format(loop.index) }}</span>
                    <span class="uf-featured__info">
                        <span class="uf-featured__name">{{ item.name }}</span>
                        <span class="uf-featured__desc">{{ item.featuredDescription ?? item.description }}</span>
                    </span>
                    <span class="uf-featured__tag">{{ item.tag }}</span>
                    <span class="uf-featured__price">{{ item.price }} €</span>
                </a>
            {% endfor %}
        </div>
    </section>

    <section class="uf-manifesto uf-graffiti">
        <div class="uf-container uf-manifesto__inner">
            <div>
                <div data-reveal="0" class="uf-manifesto__label">— LE PRINCIPE</div>
                <p data-reveal="100" class="uf-manifesto__text">On fait peu de choses, mais on les fait <span class="uf-manifesto__accent">tous les jours, à la main,</span> depuis 2021.</p>
                <a data-reveal="220" href="{{ path('app_histoire') }}" class="uf-manifesto__link">LIRE L'HISTOIRE →</a>
            </div>
            <div data-reveal="180" class="uf-manifesto__visual">
                <span>[ photo — cuisine ouverte, service ]</span>
            </div>
        </div>
    </section>

    <section class="uf-infos">
        <div class="uf-container uf-infos__grid">
            <div data-reveal="0" class="uf-infos__cell">
                <div class="uf-infos__label">ADRESSE</div>
                <div class="uf-infos__value">À l'Horloge<br>69160 Tassin</div>
            </div>
            <div data-reveal="100" class="uf-infos__cell">
                <div class="uf-infos__label">HORAIRES</div>
                <div class="uf-infos__value">7j/7<br>11h — 23h</div>
            </div>
            <div data-reveal="200" class="uf-infos__cell">
                <div class="uf-infos__label">SUR PLACE OU À EMPORTER</div>
                <div class="uf-infos__value">04 72 00 00 00<br>@urbansfood</div>
            </div>
        </div>
    </section>
{% endblock %}
