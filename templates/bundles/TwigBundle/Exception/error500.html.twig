{% extends 'base.html.twig' %}

{% block title %}Erreur serveur — Urban's Food{% endblock %}
{% block robots %}<meta name="robots" content="noindex">{% endblock %}

{% block body %}
    <div class="uf-error">
        <div class="uf-container uf-error__inner">
            <div class="uf-error__label">ERREUR 500 — PROBLÈME EN CUISINE</div>
            <h1 class="uf-error__title">On a cramé<br><span class="uf-error__accent">un truc.</span></h1>
            <p class="uf-error__text">
                Un pépin technique de notre côté. On est dessus — réessaie dans un instant.
            </p>
            <div class="uf-error__actions">
                <a href="{{ path('app_home') }}" class="uf-error__cta">Retour à l'accueil →</a>
            </div>
        </div>
    </div>
{% endblock %}
